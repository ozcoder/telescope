{
  "name": "@cloudflare/telescope",
  "version": "1.0.0",
  "description": "Cross-browser performance testing agent and library, built on Playwright. Collects HAR, Web Vitals, screenshots, filmstrip, and video.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/src/index.d.ts",
        "default": "./dist/src/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "img",
    "support"
  ],
  "bin": {
    "telescope": "dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/src/cli.js && cp -r src/templates dist/src/ && mkdir -p dist/processors/templates && cp -r processors/templates/* dist/processors/templates/",
    "dev": "tsc --watch",
    "start": "node dist/src/cli.js",
    "test": "npm run build && vitest run",
    "test:ci": "export CI=true; npm test",
    "coverage": "vitest run --coverage",
    "clean": "rm -rf node_modules results dist",
    "clean:results": "rm -rf results",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prettier": "npx prettier --write .",
    "prepublishOnly": "npm run build",
    "postinstall": "npx playwright install"
  },
  "keywords": [
    "performance",
    "testing",
    "browser",
    "playwright",
    "web-vitals",
    "har",
    "lighthouse",
    "page-load",
    "cloudflare"
  ],
  "author": "Cloudflare Inc.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cloudflare/telescope.git",
    "directory": "packages/telescope"
  },
  "homepage": "https://github.com/cloudflare/telescope#readme",
  "bugs": {
    "url": "https://github.com/cloudflare/telescope/issues"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/adm-zip": "^0.5.7",
    "@types/ejs": "^3.1.5",
    "@types/node": "^25.2.1",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^4.0.6",
    "eslint": "^9.39.2",
    "msw": "^2.12.10",
    "prettier": "^3.6.2",
    "prettier-plugin-ejs": "^1.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.6"
  },
  "dependencies": {
    "@sitespeed.io/throttle": "^5.0.0",
    "adm-zip": "^0.5.16",
    "commander": "^10.0.0",
    "ejs": "^3.1.10",
    "ffmpeg": "^0.0.4",
    "playwright": "^1.59.1",
    "playwright-webkit": "^1.59.1",
    "zod": "^3.25.76"
  },
  "engines": {
    "node": ">=24"
  }
}
