---
export interface Props {
  heading: string;
  metrics: Array<{
    label: string;
    value: string | null;
    unit?: string;
    rating?: 'good' | 'needs-improvement' | 'poor';
  }>;
}

const { heading, metrics } = Astro.props;
---

<section class="metrics-section">
  <h3>{heading}</h3>
  <div class="metrics-grid">
    {
      metrics.map(m => (
        <div class="metric-card">
          <p class="label">{m.label}</p>
          {m.value !== null ? (
            <p class={`value ${m.rating ?? ''}`}>
              {m.value}
              {m.unit && <span class="unit">{m.unit}</span>}
            </p>
          ) : (
            <p class="value empty">—</p>
          )}
        </div>
      ))
    }
  </div>
</section>

<style>
  .metrics-section {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .metrics-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .metric-card {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: 0.75rem;
    padding: 1rem 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    min-width: 7rem;
    width: 7rem;
  }

  .label {
    font-size: 0.6875rem;
    font-weight: 500;
    color: var(--muted);
    margin: 0;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .value {
    font-size: 1.5rem;
    font-weight: 600;
    margin: 0;
    color: var(--text);
    line-height: 1.2;
  }

  .value.good {
    color: var(--color-success);
  }

  .value.needs-improvement {
    color: var(--color-warning);
  }

  .value.poor {
    color: var(--color-danger);
  }

  .value.empty {
    color: var(--muted);
  }

  .unit {
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--muted);
    margin-left: 0.25rem;
  }
</style>
